# ─── EmailJS ─────────────────────────────────────────────────────────────
# Sign up free at https://www.emailjs.com
# Dashboard → Email Services → Add New Service   → copy Service ID
# Dashboard → Email Templates → Create Template  → copy Template ID
# Dashboard → Account → API Keys                 → copy Public Key

VITE_EMAILJS_SERVICE_ID=service_xxxxxxx
VITE_EMAILJS_TEMPLATE_ID=template_xxxxxxx
VITE_EMAILJS_PUBLIC_KEY=xxxxxxxxxxxxxxxx

# ─── EmailJS template variables expected ─────────────────────────────────
# {{to_name}}    — your name (auto-filled from personalInfo.name)
# {{from_name}}  — sender's name
# {{from_email}} — sender's email
# {{subject}}    — message subject
# {{message}}    — message body
